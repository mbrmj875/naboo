# انسخ إلى .env.local واملأ القيم. لا ترفع .env.local إلى Git.

# نفس مشروع Supabase المستخدم في التطبيق (راجع lib/services/supabase_config.dart)
NEXT_PUBLIC_SUPABASE_URL=https://rkofqwcuvbzrnmelvxhz.supabase.co

# من Supabase Dashboard → Project Settings → API → service_role (سري — للخادم فقط)
SUPABASE_SERVICE_ROLE_KEY=

# كلمة مرور دخول لوحة الإدارة (اختر كلمة قوية)
NABOO_ADMIN_PASSWORD=

# سر توقيع الجلسة — سلسلة عشوائية طويلة (مثلاً 32 حرفاً فأكثر)
NABOO_SESSION_SECRET=
