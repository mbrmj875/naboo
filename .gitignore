#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Release signing (never commit)
/android/key.properties
/android/upload-keystore.jks

# --- NABOO project specific ignores ---

# Secrets & local env (never commit — يظهر «Source code» في كل إصدار GitHub)
.env
.env.*
!.env.example
*.pem
secrets/

# Local backup snapshots (do not push to GitHub)
*.backup

# Built distributables (rebuilt via CI release workflows)
/dist/

# Node modules for the admin-web sub-project
admin-web/node_modules/
admin-web/.next/
admin-web/out/

# Local Firebase Hosting cache
.firebase/

# عوائد بناء TypeScript / npm خاطئ من جذر المشروع
*.tsbuildinfo
/package-lock.json
